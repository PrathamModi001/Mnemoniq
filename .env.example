# Copy this to .env (dev) or .env.production and fill in your values.
# Never commit .env or .env.production — they are gitignored.

# Environment: "development" | "production"
APP_ENV=development

# PostgreSQL — required for multi-instance deployment
DATABASE_URL=postgresql://memoryweave:memoryweave@localhost:5432/memoryweave

# ChromaDB server mode — set CHROMA_HOST to use HTTP client instead of local file
CHROMA_HOST=
CHROMA_PORT=8000

# Redis session cache — leave empty to disable
REDIS_URL=

# Storage paths — legacy dev fallback when DATABASE_URL / CHROMA_HOST are not set
CHROMA_PATH=./data/dev/chroma
KG_STORE_PATH=./data/dev/kg_store.json
EVAL_DB_PATH=./data/dev/metrics.db

# CORS — list the exact frontend origin(s); never use ["*"] with credentials
CORS_ORIGINS=["http://localhost:3000"]

# Ollama (local inference — no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# LangSmith tracing (optional)
# Set both LANGSMITH_TRACING and LANGCHAIN_TRACING_V2 for compatibility with all langchain versions.
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=memory-weave

# LLM provider: "ollama" | "huggingface"
LLM_PROVIDER=ollama

# HuggingFace (used when LLM_PROVIDER=huggingface)
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_EXTRACTION_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_API_KEY=hf_...

# Auth (NextAuth.js + FastAPI shared secret)
AUTH_SECRET=           # generate with: openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=
